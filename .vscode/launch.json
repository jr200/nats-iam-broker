{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Process",
            "type": "go",
            "request": "attach",
            "mode": "local",
            "processId": 0
        },
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/cmd/nats-iam-broker/main.go",
            "args": [
                "serve",
                "--log-format", "human",
                // "--log-level", "trace",
                "${workspaceFolder}/configs/env_minter.yaml",
                "${workspaceFolder}/configs/idp_private.yaml",
                "${workspaceFolder}/configs/idp_public.yaml",
                "${workspaceFolder}/configs/idp_mock.yaml",
                "${workspaceFolder}/examples/basic/rbac.yaml"
            ],
            "env": {
                "NATS_URL": "nats://localhost:4222",
                "SECRET_STORE": "/Users/user/code/nats-iam-broker/assets/pki",
                "IAM_NAME": "nats-iam-broker",
                "IAM_VERSION": "0.0.11",
                "IAM_DESCRIPTION": "nats-iam-broker Jwt Minting Service",
                "IAM_ACCOUNT_NAME": "MINTER",
                "IAM_USER_CREDS": "$SECRET_STORE/nats/nsc/keys/creds/OP_DEV/MINTER/auth.creds",
                "IAM_ACCOUNT_SIGNK": "$SECRET_STORE/Accounts/MINTER/acct-signing-key.nk",
                "IAM_SERVICE_XK": "$SECRET_STORE/Accounts/MINTER/acct-encryption-key.xk"
            }
        },
        {
            "name": "Launch: debug local build",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "init_debug_env",
            "program": "${workspaceFolder}/cmd/nats-iam-broker/main.go",
            "args": [
                "serve",
                "--log-level", "trace",
                "--log-sensitive",
                "--log-format", "human",
                "${workspaceFolder}/docker/config/*.yaml",
                "/tmp/nats-iam-broker/*.yaml"
            ],
            "envFile": "${workspaceFolder}/.env.local",
        }
    ]
}